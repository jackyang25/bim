# ─── Boundary Integrity Monitor — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.
# All variables are optional — defaults are shown in comments.

# ─── Required ─────────────────────────────────────────────────────────────────

# Anthropic API key for the annotation backend.
# Without this key, all checks fail-safe to human_review.
ANTHROPIC_API_KEY=sk-ant-...

# ─── Annotation Backend ───────────────────────────────────────────────────────

# Claude model used for boundary annotation.
# Recommendation: use claude-haiku-4-5 for production to minimise latency and cost.
# Use claude-sonnet-4-6 or higher for higher-stakes deployments.
# Default: claude-sonnet-4-20250514
ANNOTATION_MODEL=claude-sonnet-4-20250514

# Maximum time (ms) to wait for an annotation response before failing.
# If the annotation times out, the check routes to human_review (fail-safe).
# Default: 30000 (30 seconds)
ANNOTATION_TIMEOUT_MS=30000

# Number of retry attempts after an annotation failure (network error, parse error, etc.).
# Total attempts = 1 + ANNOTATION_MAX_RETRIES.
# Default: 1 (2 total attempts)
ANNOTATION_MAX_RETRIES=1

# ─── Input Size Limits ────────────────────────────────────────────────────────

# Maximum characters allowed in user_input.
# Requests exceeding this are rejected with input_too_large error.
# Default: 10000
MAX_USER_INPUT_CHARS=10000

# Maximum characters allowed in agent_output.
# Default: 10000
MAX_AGENT_OUTPUT_CHARS=10000

# Maximum number of session history exchanges.
# Default: 20
MAX_SESSION_HISTORY_ITEMS=20

# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Maximum check_boundary_integrity calls per 60-second sliding window.
# This protects the annotation API (paid external call) from flooding.
# In-memory, resets on server restart.
# Default: 60
MAX_REQUESTS_PER_MINUTE=60

# ─── Bayesian Prior Source ────────────────────────────────────────────────────
# Controls where the Bayesian classifier gets its initial beliefs about
# how often each category of flag is a real failure.
#
# "uniform" — Beta(1,1) per category. Zero knowledge. Conservative default:
#             every flagged category starts at 0.5 probability (→ human_review).
#             Self-calibrates as verdicts accumulate. Use for new deployments.
#
# "config"  — Load per-category Beta priors from a JSON file.
#             Use when domain experts can estimate confirmation rates.
#             E.g., "scope violations are confirmed ~70% of the time" → alpha=7, beta=3.
#
# "pooled"  — Compute priors from a shared verdict pool across deployment sites.
#             Use in multi-site consortiums so new sites inherit collective experience.
#
# Default: uniform
PRIOR_SOURCE=uniform

# Path to JSON file with per-category Beta priors (only used when PRIOR_SOURCE=config).
# Format: { "scope": {"alpha": 7, "beta": 3}, "escalation": {"alpha": 8, "beta": 2}, ... }
# See examples/priors.json for the expected format.
# PRIOR_CONFIG_PATH=/path/to/priors.json

# ─── Routing Thresholds ──────────────────────────────────────────────────────
# The Bayesian classifier produces per-category risk scores (posterior means).
# The router compares these against the thresholds below to decide routing.
# Tune these per deployment based on your tolerance for false alarms vs misses.

# P(confirmed_failure) threshold above which escalation_integrity triggers escalate_now.
# Lower than T_ESCALATE because the clinical consequence of a miss is higher.
# Default: 0.70
T_ESCALATE_SAFETY=0.70

# P(confirmed_failure) threshold above which any other category triggers escalate_now.
# Default: 0.85
T_ESCALATE=0.85

# P(confirmed_failure) threshold above which any category triggers human_review.
# Default: 0.40
T_REVIEW=0.40

# P(confirmed_failure) threshold above which a result is logged (log_only).
# Below this threshold the check passes silently.
# Default: 0.10
T_NOISE=0.10

# ─── Storage ──────────────────────────────────────────────────────────────────

# Absolute path to the JSON file where human review verdicts are stored.
# The file is created automatically if it does not exist.
# Default: <dist-dir>/../verdicts.json  (next to the compiled dist/ directory)
VERDICTS_PATH=/data/verdicts.json

# Absolute path to the NDJSON audit log file.
# One JSON object per line; append-only.
# The file is created automatically if it does not exist.
# Default: <dist-dir>/../audit.ndjson
AUDIT_LOG_PATH=/data/audit.ndjson
